{
  "name": "@taurus-swap/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for TaurusSwap — a concentrated-liquidity stablecoin AMM on Algorand",
  "license": "MIT",
  "author": "Kaushik Samadder",
  "keywords": [
    "algorand",
    "amm",
    "defi",
    "stablecoin",
    "swap",
    "taurusswap",
    "concentrated-liquidity",
    "algosdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Kaushik2003/taurusSwap.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Kaushik2003/taurusSwap#readme",
  "bugs": {
    "url": "https://github.com/Kaushik2003/taurusSwap/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "algosdk": "^3.0.0"
  },
  "devDependencies": {
    "@algorandfoundation/algokit-utils": "^8.0.0",
    "@types/node": "^20.0.0",
    "algosdk": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
